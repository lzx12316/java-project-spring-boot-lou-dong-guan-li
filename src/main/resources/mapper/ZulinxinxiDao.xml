<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ZulinxinxiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ZulinxinxiEntity" id="zulinxinxiMap">
        <result property="fangyuanmingcheng" column="fangyuanmingcheng"/>
        <result property="dizhi" column="dizhi"/>
        <result property="fangyuanleixing" column="fangyuanleixing"/>
        <result property="fangyuanchengshi" column="fangyuanchengshi"/>
        <result property="fengmian" column="fengmian"/>
        <result property="mianji" column="mianji"/>
        <result property="yuezu" column="yuezu"/>
        <result property="yajin" column="yajin"/>
        <result property="dingjin" column="dingjin"/>
        <result property="zongjine" column="zongjine"/>
        <result property="zuhuzhanghao" column="zuhuzhanghao"/>
        <result property="zuhuxingming" column="zuhuxingming"/>
        <result property="shouji" column="shouji"/>
        <result property="qiandingshijian" column="qiandingshijian"/>
        <result property="ispay" column="ispay"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ZulinxinxiVO" >
		SELECT * FROM zulinxinxi  zulinxinxi         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ZulinxinxiVO" >
		SELECT  zulinxinxi.* FROM zulinxinxi  zulinxinxi 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ZulinxinxiView" >

		SELECT  zulinxinxi.* FROM zulinxinxi  zulinxinxi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ZulinxinxiView" >
		SELECT * FROM zulinxinxi  zulinxinxi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM zulinxinxi
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM zulinxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM zulinxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM zulinxinxi
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM zulinxinxi
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
